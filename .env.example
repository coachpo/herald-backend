# Beacon Spear — backend configuration.
# cp .env.example .env

# Django core.
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECRET_KEY=change-me

# Frontend URL used in verification/reset email links.
APP_BASE_URL=http://localhost:3000

# Auth / tokens.
JWT_SIGNING_KEY=change-me
TOKEN_HASH_KEY=change-me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Feature flags.
ALLOW_USER_SIGNUP=true
REQUIRE_VERIFIED_EMAIL_FOR_INGEST=true

# Channel config encryption (Fernet key, generate with python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())").
CHANNEL_CONFIG_ENCRYPTION_KEY=

# Ingest limits.
MAX_INGEST_BYTES=1048576

# Delivery worker.
DELIVERY_MAX_ATTEMPTS=10
DELIVERY_BACKOFF_BASE_SECONDS=5
DELIVERY_BACKOFF_MAX_SECONDS=1800

# Bark channel.
BARK_REQUEST_TIMEOUT_SECONDS=5
BARK_BLOCK_PRIVATE_NETWORKS=true

# ntfy channel.
NTFY_REQUEST_TIMEOUT_SECONDS=5
NTFY_BLOCK_PRIVATE_NETWORKS=true

# MQTT channel.
MQTT_SOCKET_TIMEOUT_SECONDS=5
MQTT_BLOCK_PRIVATE_NETWORKS=true

# SMTP (optional — leave blank to disable email sending).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@localhost